{%- comment -%}
  Hero Slideshow — converted from page.tsx hero section
  Uses isyf-hero-* classes from isyf-base.css
{%- endcomment -%}

{%- liquid
  assign hero_image = section.settings.image
  assign heading    = section.settings.heading
  assign subheading = section.settings.subheading
  assign btn_label  = section.settings.button_label
  assign btn_url    = section.settings.button_url
-%}

<section class="isyf-hero">
  {%- if hero_image != blank -%}
    <img class="isyf-hero-bg" src="{{ hero_image | image_url: width: 2000 }}" alt="" loading="eager">
  {%- else -%}
    <img class="isyf-hero-bg" src="{{ 'hero-bg.jpg' | asset_url }}" alt="" loading="eager">
  {%- endif -%}
  <div class="isyf-hero-overlay"></div>
  <div class="isyf-hero-content">
    {%- if heading != blank -%}
      <h1 class="isyf-hero-title">{{ heading }}</h1>
    {%- endif -%}
    {%- if subheading != blank -%}
      <span class="isyf-hero-subtitle">{{ subheading }}</span>
    {%- endif -%}
    {%- if btn_label != blank -%}
      {% render 'button', label: btn_label, variant: 'bright', url: btn_url %}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "class": "isyf-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "I SEE, YOU FEEL."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "WEAR WHAT YOU FEEL"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "EXPLORE"
    },
    {
      "type": "text",
      "id": "button_url",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
