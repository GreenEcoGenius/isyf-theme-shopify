{%- comment -%}
  404 Page — page not found
  Uses isyf-page-layout-* classes from isyf-base.css
{%- endcomment -%}

<div class="isyf-page-layout">
  <div class="isyf-page-layout-content" style="text-align: center; display: flex; flex-direction: column; align-items: center; gap: 24px;">
    <h1 class="isyf-page-layout-title">Page not found</h1>
    <p class="isyf-brand-story-text" style="max-width: 420px;">The page you're looking for doesn't exist or has been moved.</p>
    {% render 'button', label: 'BACK TO HOME', variant: 'dark', url: '/' %}
  </div>
</div>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "settings": []
}
{% endschema %}
