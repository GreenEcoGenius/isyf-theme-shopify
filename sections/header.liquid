{%- comment -%}
  ISYF Header — hamburger + centered logo + right links
  All navigation lives in the drawer menu.
  Uses isyf-nav-* classes from isyf-base.css
{%- endcomment -%}

{%- liquid
  assign logo = section.settings.logo
-%}

<style>
  .isyf-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 60px;
    position: absolute;
    top: 0;
    left: 0;
    background-color: var(--White);
    border-bottom: var(--border-1);
    padding: 0 var(--padding-40);
    z-index: 100;
    box-sizing: border-box;
  }
  .isyf-nav-hamburger {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 101;
  }
  .isyf-nav-hamburger-line {
    width: 22px;
    height: 1px;
    background-color: var(--Black);
  }
  .isyf-header-logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    text-decoration: none;
    z-index: 1;
  }
  .isyf-header-logo-img {
    height: 130px;
    width: auto;
    display: block;
  }
  .isyf-header-logo-text {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--Black);
    white-space: nowrap;
  }
  .isyf-header-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .isyf-header-right .isyf-nav-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--Black);
    cursor: pointer;
    transition: opacity 0.3s;
    background: none;
    border: none;
    padding: 0;
    white-space: nowrap;
  }
  .isyf-header-right .isyf-nav-link:hover {
    opacity: 0.5;
  }
  .isyf-header-mobile-bag {
    display: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--Black);
  }
  .isyf-nav-drawer-sub-menu {
    display: none;
  }
  .isyf-nav-drawer-group.is-expanded .isyf-nav-drawer-sub-menu {
    display: flex;
  }
  @media (max-width: 1024px) {
    .isyf-nav { padding: 0 24px; }
  }
  @media (max-width: 768px) {
    .isyf-header-right { display: none; }
    .isyf-header-mobile-bag { display: block; }
    .isyf-header-logo-img { height: 95px; }
    .isyf-header-logo-text { font-size: 14px; }
    .isyf-nav-drawer,
    .isyf-nav-drawer.isyf-nav-drawer-open { width: 100%; max-width: 100%; }
  }
</style>

<header class="isyf-nav" data-header>
  {%- comment -%} Left: hamburger — always visible {%- endcomment -%}
  <button class="isyf-nav-hamburger" data-drawer-toggle aria-label="Menu" aria-expanded="false">
    <span class="isyf-nav-hamburger-line"></span>
    <span class="isyf-nav-hamburger-line"></span>
  </button>

  {%- comment -%} Center: logo {%- endcomment -%}
  <a href="/" class="isyf-header-logo">
    {%- if logo != blank -%}
      <img
        src="{{ logo | image_url: width: 400 }}"
        alt="{{ shop.name }}"
        loading="eager"
        class="isyf-header-logo-img"
      >
    {%- else -%}
      <img
        src="{{ 'logo-isyf.png' | asset_url }}"
        alt="{{ shop.name }}"
        loading="eager"
        class="isyf-header-logo-img"
      >
    {%- endif -%}
  </a>

  {%- comment -%} Right: account, search, bag (desktop) {%- endcomment -%}
  <nav class="isyf-header-right">
    <a href="{{ routes.account_url }}" class="isyf-nav-link">
      {%- if customer -%}Account{%- else -%}Sign in{%- endif -%}
    </a>
    <a href="{{ routes.search_url }}" class="isyf-nav-link">Search</a>
    <a href="{{ routes.cart_url }}" class="isyf-nav-link">Bag ({{ cart.item_count }})</a>
  </nav>

  {%- comment -%} Right: bag only (mobile) {%- endcomment -%}
  <a href="{{ routes.cart_url }}" class="isyf-header-mobile-bag">Bag ({{ cart.item_count }})</a>
</header>

