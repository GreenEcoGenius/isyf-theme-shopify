{%- comment -%} Overlay {%- endcomment -%}
<div class="isyf-nav-overlay" data-drawer-overlay style="display:none;"></div>

<script>
  (function () {
    var drawer = document.querySelector('[data-drawer]');
    var overlay = document.querySelector('[data-drawer-overlay]');
    var toggleBtns = document.querySelectorAll('[data-drawer-toggle]');
    var closeBtns = document.querySelectorAll('[data-drawer-close]');
    var groupToggles = document.querySelectorAll('[data-drawer-group-toggle]');

    function openDrawer() {
      drawer.classList.add('isyf-nav-drawer-open');
      overlay.style.display = 'block';
      document.body.style.overflow = 'hidden';
      toggleBtns.forEach(function (b) { b.setAttribute('aria-expanded', 'true'); });
    }

    function closeDrawer() {
      drawer.classList.remove('isyf-nav-drawer-open');
      overlay.style.display = 'none';
      document.body.style.overflow = '';
      toggleBtns.forEach(function (b) { b.setAttribute('aria-expanded', 'false'); });
      groupToggles.forEach(function (g) {
        g.closest('[data-drawer-group]').classList.remove('is-expanded');
        g.querySelector('span').textContent = '+';
      });
    }

    toggleBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        drawer.classList.contains('isyf-nav-drawer-open') ? closeDrawer() : openDrawer();
      });
    });

    closeBtns.forEach(function (btn) { btn.addEventListener('click', closeDrawer); });
    overlay.addEventListener('click', closeDrawer);

    groupToggles.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var group = btn.closest('[data-drawer-group]');
        var isOpen = group.classList.contains('is-expanded');
        groupToggles.forEach(function (g) {
          g.closest('[data-drawer-group]').classList.remove('is-expanded');
          g.querySelector('span').textContent = '+';
        });
        if (!isOpen) {
          group.classList.add('is-expanded');
          btn.querySelector('span').textContent = '−';
        }
      });
    });

    drawer.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeDrawer);
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "isyf-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Displayed in the center of the navigation bar. Falls back to shop name if empty."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 250,
      "step": 10,
      "default": 200,
      "unit": "px",
      "label": "Logo width"
    }
  ]
}
{% endschema %}
