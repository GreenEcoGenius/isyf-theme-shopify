{%- comment -%}
  Instagram Feed — converted from InstagramSection.tsx
  Uses isyf-instagram-* classes from isyf-base.css
{%- endcomment -%}

{%- liquid
  assign subtitle = section.settings.subtitle
  assign heading  = section.settings.heading
  assign ig_url   = section.settings.instagram_url
-%}

<section class="isyf-instagram">
  <div class="isyf-instagram-header">
    {%- if subtitle != blank -%}
      <span class="isyf-instagram-subtitle">{{ subtitle }}</span>
    {%- endif -%}
    {%- if heading != blank -%}
      {%- if ig_url != blank -%}
        <a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer" style="text-decoration: none;">
          <h2 class="isyf-instagram-title">{{ heading }}</h2>
        </a>
      {%- else -%}
        <h2 class="isyf-instagram-title">{{ heading }}</h2>
      {%- endif -%}
    {%- endif -%}
  </div>

  <div class="isyf-instagram-grid">
    {%- for block in section.blocks -%}
      {%- if block.settings.image != blank -%}
        <div class="isyf-instagram-image-wrapper" {{ block.shopify_attributes }}>
          {%- if ig_url != blank -%}
            <a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer">
              <img
                class="isyf-instagram-image"
                src="{{ block.settings.image | image_url: width: 480 }}"
                alt="{{ block.settings.alt | default: 'Instagram post' | escape }}"
                loading="lazy"
              >
            </a>
          {%- else -%}
            <img
              class="isyf-instagram-image"
              src="{{ block.settings.image | image_url: width: 480 }}"
              alt="{{ block.settings.alt | default: 'Instagram post' | escape }}"
              loading="lazy"
            >
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- if section.blocks.size == 0 -%}
      {%- for i in (1..5) -%}
        <div class="isyf-instagram-image-wrapper">
          {%- if ig_url != blank -%}
            <a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer">
              <img class="isyf-instagram-image" src="{{ 'ig-' | append: i | append: '.jpg' | asset_url }}" alt="Instagram post" loading="lazy">
            </a>
          {%- else -%}
            <img class="isyf-instagram-image" src="{{ 'ig-' | append: i | append: '.jpg' | asset_url }}" alt="Instagram post" loading="lazy">
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Instagram feed",
  "class": "isyf-instagram-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Handle / Heading",
      "default": "@ISYF_OFF"
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram profile URL",
      "default": "https://instagram.com/isyf_off"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram feed",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
