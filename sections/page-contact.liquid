{%- comment -%}
  Contact Page
  Uses isyf-contact-* classes from isyf-base.css
{%- endcomment -%}

<div class="isyf-contact-page">
  <div class="isyf-contact-content">
    <h1 class="isyf-contact-title">{{ section.settings.title }}</h1>
    <p class="isyf-contact-subtitle">{{ section.settings.subtitle }}</p>

    <div class="isyf-contact-layout">
      <div class="isyf-contact-info-side">
        <div class="isyf-contact-info-block">
          <span class="isyf-contact-info-label">Email</span>
          <span class="isyf-contact-info-value">contact@iseeyoufeel.com</span>
        </div>
        <div class="isyf-contact-info-block">
          <span class="isyf-contact-info-label">Instagram</span>
          <a href="https://instagram.com/isyf_off" target="_blank" rel="noopener" class="isyf-contact-info-value" style="text-decoration: none;">@isyf_off</a>
        </div>
        <div class="isyf-contact-info-block">
          <span class="isyf-contact-info-label">TikTok</span>
          <a href="https://tiktok.com/@iseeyoufeel" target="_blank" rel="noopener" class="isyf-contact-info-value" style="text-decoration: none;">@iseeyoufeel</a>
        </div>
        <div class="isyf-contact-info-block">
          <span class="isyf-contact-info-label">Response time</span>
          <span class="isyf-contact-info-value">Within 24 hours</span>
        </div>
      </div>

      <div class="isyf-contact-form">
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <p style="padding: 16px; background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; font-size: 14px; text-align: center;">Thank you for your message. We will get back to you within 24 hours.</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p style="padding: 16px; background: #fef2f2; border: 1px solid #fecaca; color: var(--Red); font-size: 14px; text-align: center;">
              {{ form.errors | default_errors }}
            </p>
          {%- endif -%}
          <input type="text" name="contact[name]" placeholder="Name" class="isyf-contact-input" required>
          <input type="email" name="contact[email]" placeholder="Email" class="isyf-contact-input" required>
          <input type="text" name="contact[subject]" placeholder="Subject" class="isyf-contact-input">
          <textarea name="contact[body]" placeholder="Your message" class="isyf-contact-textarea" required></textarea>
          {% render 'button', label: 'SEND MESSAGE', variant: 'solid', full_width: true %}
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "GET IN TOUCH"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Whether you have a question about sizing, shipping, or just want to say hello - reach out."
    }
  ]
}
{% endschema %}
