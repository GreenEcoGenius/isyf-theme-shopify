{%- comment -%}
  Main Blog — articles grid
  Uses isyf-journal-* classes from isyf-base.css
{%- endcomment -%}

<div class="isyf-journal-page">
  <section class="isyf-journal-content">
    <h1 class="isyf-journal-title">{{ blog.title }}</h1>

    {%- paginate blog.articles by 9 -%}
      {%- if blog.articles.size > 0 -%}
        <div class="isyf-journal-articles-grid">
          {%- for article in blog.articles -%}
            <a href="{{ article.url }}" class="isyf-journal-article">
              {%- if article.image != blank -%}
                <img
                  class="isyf-journal-article-image"
                  src="{{ article.image | image_url: width: 600 }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy"
                  style="object-fit: cover;"
                >
              {%- endif -%}
              {%- if article.tags.size > 0 -%}
                <span class="isyf-journal-article-label">{{ article.tags.first }}</span>
              {%- endif -%}
              <span class="isyf-journal-article-title">{{ article.title }}</span>
              <span class="isyf-journal-article-link">Read more</span>
            </a>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div style="display: flex; justify-content: center; gap: 8px; margin-top: 48px;">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="isyf-btn isyf-btn-dark">&larr; Previous</a>
            {%- endif -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="isyf-btn isyf-btn-dark">Next &rarr;</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- else -%}
        {%- assign journal_images = 'journal-1.jpg,journal-2.jpg,journal-3.jpg' | split: ',' -%}
        {%- assign journal_labels = 'Design,Style,Behind the scenes' | split: ',' -%}
        {%- assign journal_titles = 'The creative process behind ISYF,Building a conscious wardrobe,From studio to your door' | split: ',' -%}
        {%- assign journal_urls = '/pages/journal-design,/pages/journal-style,/pages/journal-studio' | split: ',' -%}
        <div class="isyf-journal-articles-grid">
          {%- for i in (0..2) -%}
            <a href="{{ journal_urls[i] }}" class="isyf-journal-article">
              <img
                class="isyf-journal-article-image"
                src="{{ journal_images[i] | asset_url }}"
                alt="{{ journal_titles[i] | escape }}"
                loading="lazy"
                style="object-fit: cover;"
              >
              <span class="isyf-journal-article-label">{{ journal_labels[i] }}</span>
              <span class="isyf-journal-article-title">{{ journal_titles[i] }}</span>
              <span class="isyf-journal-article-link">Read more</span>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </section>
</div>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "settings": []
}
{% endschema %}
