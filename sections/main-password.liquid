{%- comment -%}
  Password Page — store password gate
{%- endcomment -%}

<div style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 24px; text-align: center; font-family: var(--font-body);">
  <a href="/" class="isyf-nav-logo-link" style="position: static; transform: none; margin-bottom: 32px;">
    <span class="isyf-nav-logo-text" style="font-size: 24px;">{{ shop.name }}</span>
  </a>

  <h1 style="font-family: var(--font-heading); font-size: 32px; font-weight: 400; letter-spacing: 0.12em; margin: 0 0 16px;">Opening soon</h1>
  <p class="isyf-brand-story-text" style="max-width: 420px; margin: 0 0 40px;">
    We're putting the finishing touches on our store. Enter the password to get early access.
  </p>

  {%- form 'storefront_password' -%}
    {%- if form.errors -%}
      <p style="color: var(--Red); font-size: 14px; margin-bottom: 16px;">{{ form.errors.messages['form'] }}</p>
    {%- endif -%}
    <div style="display: flex; gap: 8px; max-width: 400px; width: 100%;">
      <input
        type="password"
        name="password"
        placeholder="Enter password"
        class="isyf-register-input"
        style="flex: 1;"
        required
      >
      <button type="submit" class="isyf-btn isyf-btn-solid">Enter</button>
    </div>
  {%- endform -%}

  <p style="margin-top: 48px; font-size: 12px; font-weight: 300; color: var(--Gray-3);">
    &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
  </p>
</div>

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "settings": []
}
{% endschema %}
