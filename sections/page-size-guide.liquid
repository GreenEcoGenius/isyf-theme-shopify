{%- comment -%}
  Size Guide
  Uses isyf-size-guide-* classes from isyf-base.css
{%- endcomment -%}

<div class="isyf-size-guide-page">
  <div class="isyf-size-guide-content">
    <h1 class="isyf-size-guide-title">Size Guide</h1>
    <p class="isyf-size-guide-note">All measurements are in centimeters. Our pieces have a relaxed contemporary fit. If you prefer a tighter fit, we recommend sizing down.</p>

    <h2 class="isyf-size-guide-table-title">T-shirts &amp; Tops</h2>
    <div class="isyf-size-guide-table-wrap">
      <table class="isyf-size-guide-table">
        <thead>
          <tr>
            <th>Size</th>
            <th>Chest</th>
            <th>Length</th>
            <th>Shoulders</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>XS</td><td>96</td><td>66</td><td>42</td></tr>
          <tr><td>S</td><td>100</td><td>68</td><td>44</td></tr>
          <tr><td>M</td><td>106</td><td>71</td><td>46</td></tr>
          <tr><td>L</td><td>112</td><td>74</td><td>49</td></tr>
          <tr><td>XL</td><td>118</td><td>76</td><td>52</td></tr>
          <tr><td>2XL</td><td>124</td><td>78</td><td>54</td></tr>
          <tr><td>3XL</td><td>130</td><td>80</td><td>56</td></tr>
        </tbody>
      </table>
    </div>

    <h2 class="isyf-size-guide-table-title">Hoodies &amp; Sweats</h2>
    <div class="isyf-size-guide-table-wrap">
      <table class="isyf-size-guide-table">
        <thead>
          <tr>
            <th>Size</th>
            <th>Chest</th>
            <th>Length</th>
            <th>Shoulders</th>
            <th>Sleeve</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>XS</td><td>102</td><td>65</td><td>44</td><td>60</td></tr>
          <tr><td>S</td><td>108</td><td>68</td><td>47</td><td>62</td></tr>
          <tr><td>M</td><td>114</td><td>71</td><td>50</td><td>63</td></tr>
          <tr><td>L</td><td>120</td><td>74</td><td>53</td><td>64</td></tr>
          <tr><td>XL</td><td>126</td><td>76</td><td>56</td><td>65</td></tr>
          <tr><td>2XL</td><td>132</td><td>78</td><td>58</td><td>66</td></tr>
          <tr><td>3XL</td><td>138</td><td>80</td><td>60</td><td>67</td></tr>
        </tbody>
      </table>
    </div>

    <h2 class="isyf-size-guide-table-title">How to Measure</h2>
    <p class="isyf-size-guide-note"><strong>Chest:</strong> Measure around the fullest part of your chest, keeping the tape level.<br><strong>Length:</strong> Measure from the highest point of the shoulder to the bottom hem.<br><strong>Shoulders:</strong> Measure from shoulder seam to shoulder seam across the back.<br><strong>Sleeve:</strong> Measure from the shoulder seam to the end of the cuff.</p>
  </div>
</div>

{% schema %}
{
  "name": "Size guide",
  "tag": "section",
  "settings": []
}
{% endschema %}
