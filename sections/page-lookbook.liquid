{%- comment -%}
  Lookbook Page — editorial showcase of ISYF collections
{%- endcomment -%}

{%- comment -%} ===== HERO ===== {%- endcomment -%}
<div class="isyf-lookbook-page">
  <div class="isyf-lookbook-hero">
    <h1 class="isyf-lookbook-hero-title">LOOKBOOK</h1>
    <p class="isyf-lookbook-hero-subtitle">See the vision. Feel the collection.</p>
  </div>

  {%- comment -%} ===== ISYF PREMIUM ===== {%- endcomment -%}
  <div class="isyf-lookbook-block">
    <div class="isyf-lookbook-block-image">
      <img src="{{ 'grid-premium.jpg' | asset_url }}" alt="ISYF Premium Collection" loading="lazy">
    </div>
    <div class="isyf-lookbook-block-text">
      <span class="isyf-lookbook-block-label">COLLECTION</span>
      <h2 class="isyf-lookbook-block-title">ISYF Premium</h2>
      <p class="isyf-lookbook-block-desc">Refined silhouettes. Premium fabrics. Pieces designed to last beyond the season. Every detail is considered, every material is chosen with intention. This is fashion that whispers — and stays with you.</p>
      {% render 'button', label: 'SHOP ISYF PREMIUM', variant: 'dark', url: '/collections/all' %}
    </div>
  </div>

  {%- comment -%} ===== ISYF FEELS ===== {%- endcomment -%}
  <div class="isyf-lookbook-block isyf-lookbook-block-reverse">
    <div class="isyf-lookbook-block-image">
      <img src="{{ 'grid-feels.jpg' | asset_url }}" alt="ISYF FEELS Collection" loading="lazy">
    </div>
    <div class="isyf-lookbook-block-text">
      <span class="isyf-lookbook-block-label">COLLECTION</span>
      <h2 class="isyf-lookbook-block-title">ISYF FEELS</h2>
      <p class="isyf-lookbook-block-desc">Bold. Relaxed. Expressive. Streetwear that speaks without trying. Made-to-order pieces that carry a message — designed for those who feel before they think, and wear what they mean.</p>
      {% render 'button', label: 'SHOP ISYF FEELS', variant: 'dark', url: '/collections/all' %}
    </div>
  </div>

  {%- comment -%} ===== EDITORIAL GRID ===== {%- endcomment -%}
  <div class="isyf-lookbook-editorial">
    <div class="isyf-lookbook-editorial-grid">
      <div class="isyf-lookbook-editorial-item isyf-lookbook-editorial-tall">
        <img src="{{ 'category-women.jpg' | asset_url }}" alt="Women's collection" loading="lazy">
      </div>
      <div class="isyf-lookbook-editorial-item">
        <img src="{{ 'story-image.jpg' | asset_url }}" alt="Craftsmanship" loading="lazy">
      </div>
      <div class="isyf-lookbook-editorial-item">
        <img src="{{ 'ig-3.jpg' | asset_url }}" alt="Street style" loading="lazy">
      </div>
      <div class="isyf-lookbook-editorial-item isyf-lookbook-editorial-tall">
        <img src="{{ 'category-men.jpg' | asset_url }}" alt="Men's collection" loading="lazy">
      </div>
      <div class="isyf-lookbook-editorial-item isyf-lookbook-editorial-wide">
        <img src="{{ 'hero-bg.jpg' | asset_url }}" alt="ISYF Campaign" loading="lazy">
      </div>
      <div class="isyf-lookbook-editorial-item">
        <img src="{{ 'ig-1.jpg' | asset_url }}" alt="On the move" loading="lazy">
      </div>
    </div>
  </div>

  {%- comment -%} ===== CTA ===== {%- endcomment -%}
  <div class="isyf-lookbook-cta">
    <h2 class="isyf-lookbook-cta-title">Feel something.</h2>
    {% render 'button', label: 'EXPLORE THE COLLECTIONS', variant: 'dark', url: '/collections/all' %}
  </div>
</div>

{% schema %}
{
  "name": "Lookbook",
  "tag": "section",
  "settings": []
}
{% endschema %}
