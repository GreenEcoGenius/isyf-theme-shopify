{%- comment -%}
  Category Grid — converted from page.tsx categoriesGrid
  Uses isyf-categories-grid / isyf-category-* classes from isyf-base.css
  Each block is a category card with image, title, and button
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  <section class="isyf-categories-grid">
    {%- for block in section.blocks -%}
      <div class="isyf-category-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            class="isyf-category-image"
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.title | escape }}"
            loading="lazy"
          >
        {%- else -%}
          {%- case block.settings.title -%}
            {%- when 'WOMEN' -%}
              <img class="isyf-category-image" src="{{ 'category-women.jpg' | asset_url }}" alt="Women" loading="lazy">
            {%- when 'MEN' -%}
              <img class="isyf-category-image" src="{{ 'category-men.jpg' | asset_url }}" alt="Men" loading="lazy">
            {%- when 'ACCESSORIES' -%}
              <img class="isyf-category-image" src="{{ 'category-accessories.jpg' | asset_url }}" alt="Accessories" loading="lazy">
            {%- else -%}
              <div class="isyf-category-image" style="background: #000;"></div>
          {%- endcase -%}
        {%- endif -%}
        <div class="isyf-category-overlay">
          {%- if block.settings.title != blank -%}
            <h3 class="isyf-category-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            {% render 'button',
              label: block.settings.button_label,
              variant: 'bright',
              url: block.settings.link
            %}
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Category grid",
  "class": "isyf-category-grid-section",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "CATEGORY"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "DISCOVER"
        },
        {
          "type": "text",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category grid",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "WOMEN",
            "button_label": "DISCOVER"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "MEN",
            "button_label": "DISCOVER"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "ACCESSORIES",
            "button_label": "DISCOVER"
          }
        }
      ]
    }
  ]
}
{% endschema %}
