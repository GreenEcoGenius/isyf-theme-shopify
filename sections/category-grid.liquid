{%- comment -%}
  Category Grid — 4-card grid: Women, Men, Accessories, Rituels
  Desktop: 4 columns | Tablet & Mobile: 2x2 grid
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  <section class="isyf-categories-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign fallback_map = 'WOMEN:category-women.jpg,MEN:category-men.jpg,ACCESSORIES:category-accessories.jpg,RITUELS:category-rituels.jpg'
        assign fallback_img = blank
        assign pairs = fallback_map | split: ','
        for pair in pairs
          assign kv = pair | split: ':'
          if block.settings.title == kv[0]
            assign fallback_img = kv[1]
          endif
        endfor
      -%}
      <div class="isyf-category-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img class="isyf-category-image" src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
        {%- elsif fallback_img != blank -%}
          <img class="isyf-category-image" src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy">
        {%- else -%}
          <div class="isyf-category-image" style="background:#000;"></div>
        {%- endif -%}
        <div class="isyf-category-overlay">
          {%- if block.settings.title != blank -%}
            <h3 class="isyf-category-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            {% render 'button', label: block.settings.button_label, variant: 'bright', url: block.settings.link %}
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Category grid",
  "class": "isyf-category-grid-section",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "CATEGORY"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "DISCOVER"
        },
        {
          "type": "text",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category grid",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "WOMEN",
            "button_label": "DISCOVER"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "MEN",
            "button_label": "DISCOVER"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "ACCESSORIES",
            "button_label": "DISCOVER"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "RITUELS",
            "button_label": "DISCOVER"
          }
        }
      ]
    }
  ]
}
{% endschema %}
